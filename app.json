{
  "expo": {
    "name": "vision-agent-mobile",
    "slug": "vision-agent-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Vision Agent 需要使用相机来理解您看到的内容。",
        "NSPhotoLibraryUsageDescription": "Vision Agent 需要访问相册以分析已有照片。",
        "NSLocationWhenInUseUsageDescription": "Vision Agent 需要位置信息来提供更准确的本地向导洞察。",
        "NSSpeechRecognitionUsageDescription": "Vision Agent 需要语音识别权限，以便将你说的话转为文字追问。",
        "NSMicrophoneUsageDescription": "Vision Agent 需要使用麦克风进行语音输入。"
      }
    },
    "android": {
      "package": "com.wubingarra.visionagent",
      "usesCleartextTraffic": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ],
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sharing",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Vision Agent 需要使用麦克风进行语音输入。",
          "speechRecognitionPermission": "Vision Agent 需要语音识别权限，以便将你说的话转为文字追问。"
        }
      ]
    ],
    "extra": {
      "apiBaseUrl": "https://vision-agent-api.onrender.com",
      "eas": {
        "projectId": "ce50e9cc-1580-4bf0-af21-05efa360e995"
      }
    },
    "owner": "wubin1987107"
  }
}
